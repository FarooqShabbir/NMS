# NMS Environment Configuration
# Copy this file to .env and update values as needed

# Application
APP_NAME="Network Monitoring System"
APP_VERSION="1.0.0"
DEBUG=false

# Database - PostgreSQL
POSTGRES_USER=nms
POSTGRES_PASSWORD=nms_secret_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nms_db

# Supabase / external PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Connection pool tuning
DB_USE_NULL_POOL=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# InfluxDB
INFLUXDB_ENABLED=true
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=nms_secret_password
INFLUXDB_ORG=nms_org
INFLUXDB_BUCKET=metrics

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
# Optional: if empty, app derives these from REDIS_* values
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
ENABLE_CELERY=true

# Startup behavior
AUTO_CREATE_TABLES=true
SEED_DEFAULT_ADMIN=true
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@nms.local
ADMIN_FULL_NAME=Administrator
ADMIN_PASSWORD=admin123

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# SNMP
SNMP_TIMEOUT=5
SNMP_RETRIES=2

# Polling Intervals (seconds)
POLLING_INTERVAL_HEALTH=60
POLLING_INTERVAL_INTERFACE=60
POLLING_INTERVAL_ROUTING=300
POLLING_INTERVAL_VPN=300

# Backup
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=90
BACKUP_GIT_ENABLED=false
BACKUP_GIT_REPO=/app/git-backups

# Email Alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=nms@yourcompany.com
ALERT_EMAIL_ENABLED=false

# Slack Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_SLACK_ENABLED=false

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
ALERT_TELEGRAM_ENABLED=false

# Frontend URL
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
